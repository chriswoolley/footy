generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Manager {
  id           Int          @id @default(autoincrement())
  username     String       @unique
  passwordHash String
  teamName     String
  email        String?
  formation    String       @default("442") // "442" or "433"
  createdAt    DateTime     @default(now())

  squad        SquadEntry[]
  bids         Bid[]
  paperTalks   PaperTalk[]
  pendingChanges PendingChange[]
}

model Team {
  id           Int       @id // matches FIFA fantasy squads[].id (1..48)
  name         String
  shortName    String
  group        String?   // 'a'..'l'
  isEliminated Boolean   @default(false)
  players      Player[]
  homeFixtures Fixture[] @relation("HomeFixtures")
  awayFixtures Fixture[] @relation("AwayFixtures")
}

model Player {
  id              Int             @id // matches FIFA fantasy players[].id
  webName         String
  firstName       String
  lastName        String
  knownName       String?         // e.g. "Vini Jr." — preferred display label when set
  teamId          Int
  team            Team            @relation(fields: [teamId], references: [id])
  position        Int             // 1=GK, 2=DEF, 3=MID, 4=FWD
  nowCost         Int             // £ × 10 (real FIFA fantasy price)
  totalPoints     Int             @default(0)
  status          String          @default("a")
  news            String          @default("")
  form            Float           @default(0)
  photoCode       Int?            // legacy FPL photo code
  percentSelected Float?          // FIFA fantasy ownership %
  oneToWatch      Boolean         @default(false)

  squad       SquadEntry[]
  bids        Bid[]
  points      PointSnapshot[]

  @@index([teamId])
  @@index([position])
}

model PointSnapshot {
  id          Int      @id @default(autoincrement())
  playerId    Int
  player      Player   @relation(fields: [playerId], references: [id])
  gameweek    Int
  points      Int      // points earned this gameweek
  value       Int      // £ × 10 at the time
  kickoffTime DateTime?
  recordedAt  DateTime @default(now())

  @@unique([playerId, gameweek])
  @@index([gameweek])
}

model SquadEntry {
  id            Int       @id @default(autoincrement())
  managerId     Int
  manager       Manager   @relation(fields: [managerId], references: [id])
  playerId      Int
  player        Player    @relation(fields: [playerId], references: [id])
  fromAt        DateTime  @default(now())
  untilAt       DateTime  // sentinel: 9999-12-31 for "still owned"
  bid           Float     // £m paid in at buy
  sellPrice     Float?    // £m received at sell (book price at the time); null while still owned
  playing       Boolean   @default(false)
  formationSlot Int?      // 0..10 slot on the pitch when playing

  @@index([managerId])
  @@index([playerId])
}

model Bid {
  id        Int      @id @default(autoincrement())
  managerId Int
  manager   Manager  @relation(fields: [managerId], references: [id])
  playerId  Int
  player    Player   @relation(fields: [playerId], references: [id])
  amount    Float    // £m
  placedAt  DateTime @default(now())
  resolved  Boolean  @default(false)
  won       Boolean  @default(false)
}

model PaperTalk {
  id        Int      @id @default(autoincrement())
  when      DateTime @default(now())
  managerId Int?
  manager   Manager? @relation(fields: [managerId], references: [id])
  teamName  String?
  playerName String?
  reason    String
  bid       Float?
}

model Audit {
  id   Int      @id @default(autoincrement())
  who  String
  what String
  when DateTime @default(now())
}

// Team-selection changes queued by the manager but not yet effective.
// They commit at `effectiveAt` (start of the next gameweek / 01:00 UTC)
// unless cancelled.
model PendingChange {
  id          Int      @id @default(autoincrement())
  managerId   Int
  manager     Manager  @relation(fields: [managerId], references: [id])
  kind        String   // "PLAY" — bring on, "BENCH" — take off
  playerId    Int
  toSlot      Int?     // formation slot 0..10 (PLAY only)
  effectiveAt DateTime
  createdAt   DateTime @default(now())

  @@index([managerId])
  @@index([effectiveAt])
}

model SyncState {
  key   String @id // "bootstrap", "live:30", etc.
  value String
  when  DateTime @updatedAt
}

// A fantasy round (group stage matchday or knockout round).
// FIFA's World Cup 2026 fantasy uses 8 rounds.
model Round {
  id        Int       @id
  status    String    // "scheduled" | "live" | "completed"
  startDate DateTime
  endDate   DateTime
  fixtures  Fixture[]
}

// A single match. id = FIFA's `tournament.id` from rounds.json.
model Fixture {
  id               Int      @id
  roundId          Int
  round            Round    @relation(fields: [roundId], references: [id])
  date             DateTime
  status           String   // "scheduled" | "in_progress" | "completed"
  period           String   // "pre_match" | "first_half" | "half_time" | "second_half" | "full_time" | ...
  minutes          Int      @default(0)
  extraMinutes     Int      @default(0)
  venueName        String
  venueCity        String
  homeSquadId      Int
  homeSquad        Team     @relation("HomeFixtures", fields: [homeSquadId], references: [id])
  awaySquadId      Int
  awaySquad        Team     @relation("AwayFixtures", fields: [awaySquadId], references: [id])
  homeScore        Int?
  awayScore        Int?
  homePenaltyScore Int?
  awayPenaltyScore Int?
  homeGoalScorers  String?  // JSON blob (goalscorers + assists)
  awayGoalScorers  String?

  @@index([roundId])
  @@index([date])
  @@index([homeSquadId])
  @@index([awaySquadId])
}
